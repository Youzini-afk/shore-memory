{
  "manifestVersion": "1.0.1",
  "name": "FileOps",
  "displayName": "深度文件操作 (FileOps)",
  "version": "1.0.1",
  "description": "深度文件操作工具，支持读写、编辑、代码检查和智能Diff。",
  "author": "PeroCore",
  "pluginType": "python-module",
  "entryPoint": "file_ops.py",
  "capabilities": {
    "invocationCommands": [
      {
        "commandIdentifier": "read_file_content",
        "description": "将PDF/Word/MD等文件转换为纯文本进行读取",
        "parameter": "文件绝对路径 (file_path)"
      },
      {
        "commandIdentifier": "list_directory",
        "description": "查看目录下的详细文件列表",
        "parameter": "目录绝对路径 (dir_path)"
      },
      {
        "commandIdentifier": "write_file",
        "description": "覆盖写入指定文件内容（自动进行代码语法检查）",
        "parameter": "目标路径 (file_path)，写入内容 (content)"
      },
      {
        "commandIdentifier": "apply_diff",
        "description": "使用 SEARCH/REPLACE 格式对文件进行局部修改",
        "parameter": "目标路径 (file_path)，要替换的原内容 (search, 必须唯一)，替换后的新内容 (replace)"
      }
    ]
  }
}