{
  "manifestVersion": "1.0.1",
  "name": "WorkspaceOps",
  "displayName": "工作台管理 (WorkspaceOps)",
  "version": "1.0.1",
  "description": "工作区管理。在专注模式下管理笔记与长期记忆。",
  "author": "PeroCore",
  "pluginType": "python-module",
  "entryPoint": "workspace_ops.py",
  "capabilities": {
    "invocationCommands": [
      {
        "commandIdentifier": "write_workspace_file",
        "description": "写入笔记。参数 filename: 文件名; content: 内容。"
      },
      {
        "commandIdentifier": "read_workspace_file",
        "description": "读取笔记。参数 filename: 文件名。"
      },
      {
        "commandIdentifier": "list_workspace_files",
        "description": "列出笔记。参数 subdir: (可选) 子目录。"
      }
    ]
  }
}
