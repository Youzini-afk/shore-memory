{
  "name": "SocialAdapter",
  "displayName": "社交助手 (SocialAdapter)",
  "version": "1.1.0",
  "description": "提供与 OneBot (QQ) 社交平台交互的能力，包括消息发送、群管理、好友管理以及记忆读取。",
  "author": "PeroCore",
  "pluginType": "python-module",
  "entryPoint": "qq_tools.py",
  "tags": ["social"],
  "capabilities": {
    "invocationCommands": [
      {
        "commandIdentifier": "qq_send_group_msg",
        "description": "发送群消息。",
        "parameter": "群号 (group_id)，内容 (message)"
      },
      {
        "commandIdentifier": "qq_send_private_msg",
        "description": "发送私聊。",
        "parameter": "QQ号 (user_id)，内容 (content)"
      },
      {
        "commandIdentifier": "qq_handle_friend_request",
        "description": "处理好友请求。",
        "parameter": "请求标识 (flag)，是否同意 (approve: True/False)，可选备注 (remark)"
      },
      {
        "commandIdentifier": "qq_delete_friend",
        "description": "删除好友。",
        "parameter": "QQ号 (user_id)，可选原因 (reason)"
      },
      {
        "commandIdentifier": "qq_get_friend_list",
        "description": "获取好友列表。",
        "parameter": "无"
      },
      {
        "commandIdentifier": "qq_get_group_list",
        "description": "获取群列表。",
        "parameter": "无"
      },
      {
        "commandIdentifier": "qq_get_stranger_info",
        "description": "获取陌生人信息。",
        "parameter": "QQ号 (user_id)"
      },
      {
        "commandIdentifier": "qq_get_group_info",
        "description": "获取群信息。",
        "parameter": "群号 (group_id)"
      },
      {
        "commandIdentifier": "qq_get_group_member_info",
        "description": "获取群成员信息。",
        "parameter": "群号 (group_id)，QQ号 (user_id)"
      },
      {
        "commandIdentifier": "search_social_memory",
        "description": "搜索社交记忆 (QQ 聊天记录总结/上下文)。当需要了解过去的对话、特定话题或某人的发言时使用。",
        "parameter": "搜索关键词 (query)"
      },
      {
        "commandIdentifier": "read_agent_memory",
        "description": "读取作为桌宠时的记忆。搜索与主人的交互记录。",
        "parameter": "搜索关键词 (query)"
      },
      {
        "commandIdentifier": "qq_notify_master",
        "description": "通知主人。主动报告重要社交事件。",
        "parameter": "通知内容 (content)，可选重要程度 (importance: low/medium/high, 默认 medium)"
      }
    ]
  }
}
