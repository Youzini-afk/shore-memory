# --- 网络 / 存储 ---
PMS_HOST=127.0.0.1
PMS_PORT=7811
PMS_DATA_DIR=./data
PMS_METADATA_DB_PATH=./data/metadata.sqlite3
PMS_TRIVIUM_DB_PATH=./data/memory.tdb
PMS_ENTITY_TRIVIUM_DB_PATH=./data/entities.tdb

# --- Worker 通信 ---
PMS_WORKER_BASE_URL=http://127.0.0.1:7812
PMS_WORKER_TIMEOUT_MS=10000
PMS_EMBEDDING_TIMEOUT_MS=1800
# 每种 worker 操作的独立超时（留空则走默认兜底）
PMS_WORKER_TIMEOUT_EMBED_MS=1500
PMS_WORKER_TIMEOUT_EMBED_BATCH_MS=3000
PMS_WORKER_TIMEOUT_EXTRACT_ENTITIES_MS=3000
PMS_WORKER_TIMEOUT_SCORE_TURN_MS=8000
PMS_WORKER_TIMEOUT_REFLECT_MS=45000

# --- 缓存 ---
PMS_RECALL_CACHE_TTL_SECS=30
PMS_EMBEDDING_CACHE_TTL_SECS=600

# --- 任务队列 ---
PMS_TASK_POLL_INTERVAL_MS=1500
PMS_TASK_WORKERS=4

# --- 召回调参 ---
PMS_SEARCH_TOP_K=12
PMS_SEARCH_EXPAND_DEPTH=2
PMS_SEARCH_MIN_SCORE=0.03
PMS_ENTITY_MIN_SCORE=0.5
PMS_ENTITY_BOOST_WEIGHT=0.5
PMS_CONTIGUITY_BOOST_WEIGHT=0.3
PMS_CONTIGUITY_BOOST_VALUE=0.4
PMS_CONTIGUITY_BEFORE=1
PMS_CONTIGUITY_AFTER=1

# --- 事件通道 ---
PMS_EVENT_CHANNEL_CAP=1024
