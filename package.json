{
  "name": "peropero-chat",
  "private": true,
  "version": "0.8.68",
  "description": "萌动链接：PeroperoChat！- 一个充满活力的 3D 桌面宠物应用",
  "author": "YoKONCy",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/YoKONCy/PeroCore.git"
  },
  "main": "dist-electron/main/index.js",
  "scripts": {
    "sync-version": "node scripts/sync-version.js",
    "predev:electron": "npm run sync-version",
    "prebuild:electron": "npm run sync-version",
    "prebuild:steam": "npm run sync-version",
    "prebuild:portable": "npm run sync-version",
    "dev:electron": "concurrently -k \"tsc -p electron/tsconfig.json -w\" \"vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:backend": "node scripts/build-backend.js",
    "build:docker": "vite build --mode docker",
    "docker:up": "cd docker && docker-compose up --build",
    "docker:down": "cd docker && docker-compose down",
    "build:electron": "npm run build:backend && node scripts/copy-native.js && vite build && tsc -p electron/tsconfig.json && electron-builder",
    "build:steam": "npm run build:backend && node scripts/copy-native.js && vite build && tsc -p electron/tsconfig.json && electron-builder --win --dir",
    "build:portable": "npm run build:backend && node scripts/copy-native.js && vite build && tsc -p electron/tsconfig.json && electron-builder --win --dir",
    "build:native": "cd src/components/avatar/native && npm install && npm run build",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "docs:dev": "vitepress dev wiki --port 6657",
    "docs:build": "vitepress build wiki",
    "docs:preview": "vitepress preview wiki --port 6657",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@element-plus/icons-vue": "^2.3.2",
    "@guolao/vue-monaco-editor": "^1.6.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.3",
    "chalk": "^4.1.2",
    "dayjs": "^1.11.19",
    "dompurify": "^3.3.1",
    "echarts": "^6.0.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.7.3",
    "element-plus": "^2.13.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.3",
    "highlight.js": "^11.11.1",
    "lucide-vue-next": "^0.562.0",
    "marked": "^17.0.1",
    "mime-types": "^3.0.2",
    "monaco-editor": "^0.55.1",
    "ms": "^2.1.3",
    "protobufjs": "^8.0.0",
    "qrcode.vue": "^3.8.0",
    "semver": "^7.7.4",
    "steamworks.js": "^0.4.0",
    "systeminformation": "^5.30.6",
    "three": "^0.182.0",
    "tree-kill": "^1.2.2",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4",
    "which": "^6.0.0",
    "winreg": "^1.2.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/fs-extra": "^11.0.4",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.0.10",
    "@types/systeminformation": "^3.23.1",
    "@types/three": "^0.182.0",
    "@types/which": "^3.0.4",
    "@types/winreg": "^1.2.36",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.2.1",
    "electron-builder": "^26.4.0",
    "esbuild": "^0.25.12",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-only-warn": "^1.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^28.1.0",
    "markdown-it-mathjax3": "^4.3.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "tailwindcss": "^3.4.17",
    "ts-proto": "^2.11.1",
    "typescript": "^5.9.3",
    "vite": "^6.2.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0",
    "wait-on": "^9.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "protobufjs",
      "vue-demi"
    ]
  },
  "overrides": {},
  "build": {
    "npmRebuild": false,
    "afterPack": "scripts/after-pack-portable.js",
    "publish": [
      {
        "provider": "github",
        "owner": "YoKONCy",
        "repo": "PeroCore"
      }
    ],
    "appId": "com.peroperochat.app",
    "productName": "萌动链接：PeroperoChat！",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "src/components/avatar/native/index.js",
      "src/components/avatar/native/index.d.ts",
      "src/components/avatar/native/package.json",
      "src/components/avatar/native/*.node"
    ],
    "asarUnpack": [
      "**/*.node",
      "**/*.dll",
      "node_modules/steamworks.js/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/native",
        "to": "native",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/venv",
          "!**/.venv",
          "!**/__pycache__",
          "!**/*.pyc",
          "!**/.git*",
          "!**/.DS_Store",
          "!**/target",
          "!**/node_modules",
          "!**/*.rs",
          "!**/Cargo.toml",
          "!**/Cargo.lock",
          "!**/*.pdb",
          "!**/nit_core/plugins/social_adapter/NapCat",
          "!**/tests",
          "!**/*.egg-info",
          "!**/build",
          "!**/.python-version",
          "!**/uv.lock",
          "!**/ruff_out.*",
          "!**/PeroCore-Electron"
        ]
      },
      {
        "from": "public/Logo.png",
        "to": "Logo.png"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "dir"
      ],
      "icon": "public/Logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  }
}
