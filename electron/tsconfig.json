{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "../dist-electron",
    "strict": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../src/*"],
      "@main/*": ["main/*"]
    },
    "types": ["vitest/globals", "node"]
  },
  "include": ["main/**/*.ts", "preload/**/*.ts", "__tests__/**/*.ts"]
}
